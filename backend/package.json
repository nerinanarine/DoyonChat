{
  "name": "doyonchat-backend",
  "version": "1.0.0",
  "description": "DoyonChat - Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "npx esbuild src/server.ts --bundle --platform=node --outfile=dist/server-bundle.js --format=cjs --watch --servedir=dist --serve=3000 2>&1 & sleep 2 && node dist/server-bundle.js",
    "dev:simple": "node dist/server-bundle.js",
    "build": "npx esbuild src/server.ts --bundle --platform=node --outfile=dist/server-bundle.js --format=cjs --packages=external",
    "start": "node dist/server-bundle.js",
    "build:dev": "npx esbuild src/server.ts --bundle --platform=node --outfile=dist/server-bundle.js --format=cjs",
    "db:init": "node dist/db-init-bundle.js",
    "db:init:dev": "npx esbuild src/db/init.ts --bundle --platform=node --outfile=dist/db-init-bundle.js --format=cjs && node dist/db-init-bundle.js",
    "test": "jest --coverage",
    "test:unit": "jest --testMatch='**/tests/unit/**/*.test.ts' --coverage",
    "test:integration": "jest --testMatch='**/tests/integration/**/*.test.ts' --coverage",
    "lint": "eslint src/ tests/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.1",
    "express": "^4.19.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.42",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5"
  }
}
